# Copy this to `.env` for deploys, or `.env.local` for local testing.
# The app loads `.env.local` if it exists, otherwise `.env`. Put DEV_GUILD_ID in
# `.env.local` (instant guild command registration); leave it out of `.env` so
# deploys register commands globally (production).

# Discord bot token (Discord Developer Portal)
DISCORD_TOKEN=

# 32-byte hex key encrypting stored eBird tokens at rest.
# Generate with: openssl rand -hex 32
EBIRD_ALERT_ENC_KEY=

# Where the encrypted state file lives (guild keys + subscriptions).
STORE_PATH=waxwing-alert-state.json

# Poll cadence in minutes during the active daytime window (min ~10 given review lag).
DEFAULT_POLL_CADENCE_MIN=15
# Poll cadence in minutes overnight (backoff — little is submitted/reviewed at night).
NIGHT_POLL_CADENCE_MIN=120
# Active window in host-local time (24h). Default 04:00–20:00.
ACTIVE_START_HOUR=4
ACTIVE_END_HOUR=20
# Timezone for the active window (host-local). e.g. America/New_York
TZ=America/New_York

# Optional: register slash commands to ONE guild for instant testing.
# Unset = global registration, which can take up to ~1h to appear in Discord.
# Enable Developer Mode in Discord, right-click your server icon → Copy Server ID.
DEV_GUILD_ID=

# Integration tests only: a token here makes `cargo test` hit the real eBird API.
# Leave unset to skip the networked tests. Get one at https://ebird.org/api/keygen
EBIRD_TEST_TOKEN=

RUST_LOG=waxwing_alert=info,serenity=warn
